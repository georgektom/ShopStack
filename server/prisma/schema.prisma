generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  description    String
  price          Float
  image          String
  inventoryCount Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
}
